#compdef phynexis-foam

_phynexis_foam_complete_dirs() {
  _files -/
}

_phynexis_foam_complete_paths() {
  _files
}

_phynexis-foam() {
  local -a static docker_static

  if (( CURRENT == 2 )); then
    static=(install prefix run shell docker completion help -h --help)
    _describe 'phynexis-foam command' static
    return 0
  fi

  case ${words[2]} in
  prefix | help | -h | --help)
    ;;
  install)
    if (( CURRENT == 3 )); then
      _files -g '*.tar.gz' -g '*.tgz'
      _phynexis_foam_complete_dirs
    fi
    ;;
  completion)
    if (( CURRENT == 3 )); then
      _values 'shell type' bash zsh
    fi
    ;;
  shell)
    if (( CURRENT == 3 )); then
      _phynexis_foam_complete_dirs
    fi
    ;;
  run)
    if (( CURRENT == 3 )); then
      _phynexis_foam_complete_paths
      _phynexis_foam_complete_dirs
    fi
    ;;
  docker)
    case ${CURRENT} in
    3)
      docker_static=(
        run shell pull install-image uninstall-image help -h --help
      )
      _describe 'docker command' docker_static
      ;;
    4)
      case ${words[3]} in
      shell)
        _phynexis_foam_complete_dirs
        ;;
      run)
        _phynexis_foam_complete_paths
        _phynexis_foam_complete_dirs
        ;;
      install-image)
        _files -g '*.tar.gz' -g '*.tgz' -g '*.tar'
        ;;
      esac
      ;;
    esac
    ;;
  esac
}
