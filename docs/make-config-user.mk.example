# Copy to make-config-user.mk at the project root (git-ignored) and edit.
#
# Components: openfoam-build/ + cli-build/ under BUILD_ROOT.
# make install / all-install: product tree from build → INSTALL_PREFIX.
# Package forms: pack (one tar) + wheel (one whl). Dist ships both;
# docker also ships host CLI pack+whl as a specialty.

OPENFOAM_VERSION = v2412

# BUILD_JOBS = 8
# BUILD_ROOT = build
# DOCKER_BUILD_ROOT = docker-build
# INSTALL_PREFIX = install
# DOCKER_INSTALL_PREFIX = docker-install
# OPENFOAM_BUILD_MODULES = 0
# OPENFOAM_BUNDLE_RUNTIME = 0

# --- Docker ---
# DOCKER_UBUNTU_VERSION = 24.04
# DOCKER_REGISTRY = ghcr.io/myorg
# DOCKER_ARCH = arm64
