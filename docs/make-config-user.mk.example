# Copy to make-config-user.mk at the project root (git-ignored) and edit.

# --- OpenFOAM version & native build ---
# Switch version: set OPENFOAM_VERSION, checkout matching tag in openfoam-source, then make openfoam.
OPENFOAM_VERSION = v2412

# BUILD_JOBS = 8
# OPENFOAM_BUILD = build/host-build
# OPENFOAM_CLI_BUILD = build/cli
# OPENFOAM_STAGE = build/stage/host-build
# OPENFOAM_BUILD_MODULES = 0
# OPENFOAM_SYSTEM_CHECK = auto
# OPENFOAM_SKIP_ALLWMAKE = auto

# --- Native pack ---
# BUILD_OPENFOAM_PACK_DIR = build/openfoam-pack
# BUILD_CLI_PACK_DIR = build/cli-pack
# BUILD_CLI_WHEEL_DIR = build/cli-wheel

